rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Pesaje voucher photos — uploaded by drivers, readable by any authenticated user
    // Path: pesajes/{fecha}/{filename}
    match /pesajes/{fecha}/{filename} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024   // 10 MB max
                   && request.resource.contentType.matches('image/.*');
      allow read:  if request.auth != null;
    }

    // Problem report photos — uploaded by drivers, readable by any authenticated user
    // Path: retiros/{retiroId}/{filename}
    match /retiros/{retiroId}/{filename} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read:  if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
